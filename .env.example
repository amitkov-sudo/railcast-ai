# App
ENV=development
LOG_LEVEL=INFO

# API service
API_HOST=0.0.0.0
API_PORT=8080

# Postgres (pipelines + API). Use component vars locally; many hosts provide a single URL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=railcast
DB_USER=railcast
DB_PASSWORD=railcast
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Inference service
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8001

# Data sources
GTFS_STATIC_URL=https://example.com/gtfs-static.zip
GTFS_RT_TRIP_UPDATES_URL=https://example.com/gtfs-rt/trip-updates.pb
GTFS_RT_VEHICLE_POSITIONS_URL=https://example.com/gtfs-rt/vehicle-positions.pb

# Storage
DATA_ROOT=./data
MODEL_PATH=./ml/models/latest_model.pkl

# GTFS static ingest (BART): folder with agency.txt, stops.txt, etc.
# GTFS_STATIC_BART_DIR=./data/raw/gtfs_static/bart/extracted
